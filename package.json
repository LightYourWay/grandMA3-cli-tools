{
	"name": "grandma3-cli-tools",
	"version": "0.3.4",
	"description": "a feature rich utility for MA3 to allow operators to take advantage of LUA easily.",
	"gma_version": "2.4.2.2",
	"scripts": {
		"build": "tstl && node scripts/build.mjs",
		"dev": "tstl --watch",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"docs": "typedoc",
		"package": "node scripts/package.mjs"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/LightYourWay/grandMA3-cli-tools.git"
	},
	"author": "Lukas Runge",
	"license": "LGPL-3.0-or-later",
	"bugs": {
		"url": "https://github.com/LightYourWay/grandMA3-cli-tools/issues"
	},
	"homepage": "https://github.com/LightYourWay/grandMA3-cli-tools#readme",
	"devDependencies": {
		"fflate": "^0.8.3",
		"grandma3-tsserver-plugin": "^0.3.0",
		"grandma3-tstl-plugin": "^0.7.1",
		"grandma3-types": "^0.10.1",
		"lua-types": "^2.14.1",
		"prettier": "3.8.3",
		"ts-node": "^10.9.2",
		"typedoc": "^0.28.19",
		"typedoc-github-theme": "^0.4.0",
		"typescript": "^6.0.2",
		"typescript-to-lua": "^1.36.0"
	}
}
